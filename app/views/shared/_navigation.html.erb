<nav class="navbar navbar-expand-lg bg-white shadow-sm" role="navigation" aria-label="Main navigation">
  <div class="container">
    <%= link_to 'Student Management', root_path, class: 'navbar-brand fw-bold text-primary' %>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <% if user_signed_in? %>
          <% if current_user.admin? %>
            <li class="nav-item"><%= link_to 'Dashboard', admin_dashboard_path, class: 'nav-link' %></li>

            <li class="nav-item"><%= link_to 'Teachers', admin_teachers_path, class: 'nav-link' %></li>
          <% else %>
            <li class="nav-item"><%= link_to 'Dashboard', teacher_dashboard_path, class: 'nav-link' %></li>
          <% end %>
          <li class="nav-item"><%= link_to 'Students', students_path, class: 'nav-link' %></li>
        <% end %>
      </ul>

      <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
        <% if user_signed_in? %>
          <li class="nav-item me-2 muted">Signed in as <strong><%= current_user.email %></strong></li>
          <li class="nav-item">
            <%= button_to 'Logout', destroy_user_session_path, method: :delete, class: 'btn btn-outline-danger btn-sm' %>
          </li>
        <% else %>
          <li class="nav-item me-2"><%= link_to 'Sign in', new_user_session_path, class: 'nav-link' %></li>
          <li class="nav-item"><%= link_to 'Sign up', new_user_registration_path, class: 'btn btn-primary btn-sm' %></li>
        <% end %>
      </ul>
    </div>
  </div>
