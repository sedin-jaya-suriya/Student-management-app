<%= form_with model: @student, local: true do |f| %>
  <div class="card">

    <% if @student.errors.any? %>
      <div class="form-group">
        <ul>
          <% @student.errors.full_messages.each do |message| %>
            <li class="text-danger"><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :name %>
      <%= f.text_field :name, class: 'form-control' %>
    </div>

    <div class="form-group">
      <%= f.label :email %>
      <%= f.email_field :email, class: 'form-control' %>
    </div>

    <div class="form-row">
      <div class="form-group">
        <%= f.label :age %>
        <%= f.number_field :age, class: 'form-control' %>
      </div>

      <div class="form-group">
        <%= f.label :course %>
        <%= f.select :course,
                     ["Ruby", "Rails", "React", "Java"],
                     {},
                     class: 'form-control' %>
      </div>
    </div>

    <div class="form-group">
      <%= f.label :city %>
      <%= f.text_field :city, class: 'form-control' %>
    </div>

    <div class="form-group">
      <%= f.label :marks %>
      <%= f.number_field :marks, class: 'form-control' %>
    </div>

    <% if current_user.admin? %>

      <div class="form-group">
        <%= f.label :teacher_id, "Assign Teacher" %>

        <%= f.collection_select(
              :teacher_id,
              User.teacher,
              :id,
              :email,
              { prompt: "Select Teacher" },
              { class: "form-control" }
            ) %>
      </div>

    <% else %>

      <!-- IMPORTANT: auto-assign teacher for normal teacher login -->
      <%= f.hidden_field :teacher_id, value: current_user.id %>

    <% end %>

    <div class="form-actions">
      <%= f.submit 'Save', class: 'btn btn-primary' %>
      <%= link_to 'Cancel', students_path, class: 'btn btn-muted' %>
    </div>

  </div>
<% end %>