<div class="card student-meta">

  <div class="info">

    <h2><%= @student.name %></h2>

    <p><strong>Email:</strong> <%= @student.email %></p>

    <p><strong>Age:</strong> <%= @student.age %></p>

    <p><strong>Course:</strong> <%= @student.course %></p>

    <p><strong>City:</strong> <%= @student.city %></p>

    <p><strong>Marks:</strong> <%= @student.marks %></p>

    <p><strong>Result:</strong> <%= @student.result %></p>

    <hr>

    <h4>Profile Photo</h4>

    <% if @student.profile_photo.attached? %>

      <div class="mb-3">

        <%= image_tag @student.profile_photo,
              width: 180,
              class: "img-thumbnail" %>

      </div>

      <%= button_to "Delete Profile Photo",
            remove_profile_photo_student_path(@student),
            method: :delete,
            data: {
              turbo_confirm: "Are you sure you want to delete the profile photo?"
            },
            class: "btn btn-danger btn-sm" %>

    <% else %>

      <p>No profile photo uploaded.</p>

    <% end %>

    <hr>

    <h4>Documents</h4>

    <% if @student.documents.attached? %>

      <table class="table table-bordered">

        <thead>
          <tr>
            <th>Document</th>
            <th>Download</th>
            <th>Delete</th>
          </tr>
        </thead>

        <tbody>

          <% @student.documents.each do |document| %>

            <tr>

              <td>
                <%= document.filename %>
              </td>

              <td>

                <%= link_to "Download",
                      rails_blob_path(
                        document,
                        disposition: "attachment"
                      ),
                      class: "btn btn-success btn-sm" %>

              </td>

              <td>

                <%= button_to "Delete",
                      remove_document_student_path(
                        @student,
                        attachment_id: document.id
                      ),
                      method: :delete,
                      data: {
                        turbo_confirm: "Are you sure you want to delete this document?"
                      },
                      class: "btn btn-danger btn-sm" %>

              </td>

            </tr>

          <% end %>

        </tbody>

      </table>

    <% else %>

      <p>No documents uploaded.</p>

    <% end %>

  </div>

  <div class="text-right">

    <%= link_to 'Edit',
          edit_student_path(@student),
          class: 'btn btn-muted' %>

    <%= link_to 'Back',
          students_path,
          class: 'btn btn-primary' %>

  </div>

</div>